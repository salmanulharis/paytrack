# =============================================================================
# PayTrack (Flutter) — Git ignore for GitHub
# =============================================================================

# --- OS & editor junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.swp
*~
*.bak

# --- IDE / tools ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
*.code-workspace
.cursor/

# --- Secrets & signing (never commit) ---
.env
.env.*
!.env.example
*.jks
*.keystore
*.p12
*.pem
key.properties
**/google-services.json
**/GoogleService-Info.plist
**/secrets.json
**/credentials.json

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
**/build/
coverage/
lcov.info
*.g.dart
*.freezed.dart
*.mocks.dart

# Generated plugin registrant (regenerated by flutter pub get)
**/generated_plugin_registrant.dart

# --- Android ---
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/.cxx/
*.apk
*.aab
*.ap_
*.dex

# Android Studio / Gradle build outputs
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# --- iOS / macOS ---
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

**/ios/**/xcuserdata/
**/ios/**/*.xcworkspace/xcuserdata/
**/ios/**/*.xcodeproj/xcuserdata/
**/ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/

**/macos/Flutter/ephemeral/
**/macos/Pods/

# --- Windows / Linux (if enabled later) ---
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# --- Web ---
**/web/.dart_tool/

# --- Flutter symbolication / obfuscation ---
app.*.symbols
app.*.map.json

# --- Docs generated locally ---
**/doc/api/

# --- Misc project artifacts ---
*.log
migrate_working_dir/
.atom/
.buildlog/
.history/
.svn/
.swiftpm/

# --- Optional: uncomment to ignore lockfile (not recommended for apps) ---
# pubspec.lock
